# Ignore git files
.git
.gitignore

# Ignore local builds and dependencies
node_modules/
.next/
out/
build/

# Ignore log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# DO NOT ignore .env.local. 
# Next.js embeds NEXT_PUBLIC_ env variables at build-time.
# Cloud Build needs access to .env.local to successfully compile the pages.
